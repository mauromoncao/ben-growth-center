# ============================================================
# DR. BEN — VPS Leads/Monitor/DB Server (porta 3001)
# Copie este arquivo para .env na VPS: /opt/dr-ben-leads/.env
# ============================================================

# Porta do servidor (padrão: 3001)
PORT=3001

# Token de autenticação para o endpoint /db/query
# Gere um token seguro: openssl rand -hex 32
# Este token deve ser o mesmo configurado como DB_TOKEN na Vercel
DB_TOKEN=seu-token-seguro-aqui
